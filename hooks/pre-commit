#!/bin/bash
# Pre-commit hook for dvx-cli
# Runs linting and tests before allowing commit

set -e

echo "Running pre-commit checks..."

if ! command -v uv >/dev/null 2>&1; then
    echo "Error: uv is required to run pre-commit checks (https://docs.astral.sh/uv/)." >&2
    exit 1
fi

cd "$(git rev-parse --show-toplevel)/dvx"

# uv resolves the dev tools (ruff, pytest, invoke) from uv.lock, so the
# checks never depend on whatever happens to be on the caller's PATH.
uv run --extra dev invoke check

echo "Pre-commit checks passed!"
